# Investment OS - Environment Configuration
# ============================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore)

# ==================================================================
# DATABASE (Supabase)
# ==================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ==================================================================
# EMAIL (Gmail SMTP)
# ==================================================================
# Gmail App Password: https://myaccount.google.com/apppasswords
V5_EMAIL_FROM=your@gmail.com
V5_EMAIL_TO=your@gmail.com
V5_EMAIL_PASSWORD=your-gmail-app-password
V5_SMTP_SERVER=smtp.gmail.com
V5_SMTP_PORT=587

# ==================================================================
# PATHS (Optional - defaults shown)
# ==================================================================
# INVESTMENT_OS_WORK_DIR=/opt/investment-os
